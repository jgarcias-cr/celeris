{
  "name": "celeris/framework",
  "description": "Monorepo for celeris framework and examples",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "celeris/framework": "*",
    "celeris/mvc": "*",
    "celeris/api": "*"
  },
  "repositories": [
    { "type": "path", "url": "packages/framework", "options": { "symlink": true } },
    { "type": "path", "url": "packages/queue-manager", "options": { "symlink": true } },
    { "type": "path", "url": "packages/notification-smtp", "options": { "symlink": true } },
    { "type": "path", "url": "packages/notification-in-app", "options": { "symlink": true } },
    { "type": "path", "url": "packages/notification-outbox", "options": { "symlink": true } },
    { "type": "path", "url": "packages/notification-realtime-gateway-websocket", "options": { "symlink": true } },
    { "type": "path", "url": "packages/notification-dispatch-worker", "options": { "symlink": true } },
    { "type": "path", "url": "packages/mvc-stub", "options": { "symlink": true } },
    { "type": "path", "url": "packages/api-stub", "options": { "symlink": true } }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Celeris\\Framework\\": "packages/framework/src/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
