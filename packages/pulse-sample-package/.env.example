# Valid values: true|false (also accepts 1|0, yes|no, on|off)
CELERIS_PULSE_ENABLED=true

# Valid values: comma-separated env names (for example: development,local,staging,production)
CELERIS_PULSE_ENVIRONMENTS=development,local

# Valid values: empty (disabled) or any non-empty token string
CELERIS_PULSE_TOKEN=

# Valid values: database|memory
CELERIS_PULSE_STORAGE=database

# Valid values: empty (use app default) or any configured DB connection name (for example: main,mysql,pgsql)
CELERIS_PULSE_DB_CONNECTION=

# Valid values: table name regex ^[A-Za-z_][A-Za-z0-9_]*$, max length 48
CELERIS_PULSE_DB_TABLE=celeris_pulse_measurements

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
CELERIS_PULSE_DB_AUTO_CREATE=true

# Valid values: route prefix path (for example: /_pulse, /_ops/pulse)
CELERIS_PULSE_ROUTE_PREFIX=/_pulse

# Valid values: comma-separated path prefixes (for example: /_pulse,/health,/metrics)
CELERIS_PULSE_IGNORE_PATHS=/_pulse,/health

# Valid values: integer 1..100000
CELERIS_PULSE_MAX_REQUEST_SAMPLES=2000

# Valid values: integer 1..100000
CELERIS_PULSE_MAX_TASK_SAMPLES=1000

# Valid values: number 1..120000 (milliseconds)
CELERIS_PULSE_SLOW_REQUEST_MS=300

# Valid values: number 1..120000 (milliseconds)
CELERIS_PULSE_SLOW_TASK_MS=200

# Valid values: integer 1..200
CELERIS_PULSE_DASHBOARD_LIMIT=20
